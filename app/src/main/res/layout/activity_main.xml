<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080c18">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="#060a14">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WORK MANAGER"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#00e676"
            android:fontFamily="monospace"
            android:letterSpacing="0.12" />

        <TextView
            android:id="@+id/headerConnectionDot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● OFFLINE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#ff8c00"
            android:fontFamily="monospace"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#1a1000"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <!-- 1dp separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0d3060" />

    <FrameLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0d3060" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#060a14"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/nav_item"
        app:itemTextColor="@color/nav_item"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
