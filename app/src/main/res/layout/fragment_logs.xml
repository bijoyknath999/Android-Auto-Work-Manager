<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#080c18">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▸ LOGS"
            android:textSize="11sp"
            android:textColor="#00b4ff"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.12" />

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Search"
            android:textAllCaps="false"
            android:textSize="10sp"
            android:textColor="#c8d8e8"
            android:backgroundTint="#263238"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnCopyLog"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Copy"
            android:textAllCaps="false"
            android:textSize="10sp"
            android:textColor="#000"
            android:backgroundTint="#00b248"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Clear"
            android:textAllCaps="false"
            android:textSize="10sp"
            android:textColor="#fff"
            android:backgroundTint="#c62828" />
    </LinearLayout>

    <!-- Search bar (hidden by default) -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="6dp">

        <EditText
            android:id="@+id/searchBox"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Filter logs…"
            android:textColor="#a8f0b8"
            android:textColorHint="#1a4025"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_input"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:singleLine="true"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnCopyMatching"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Copy Matched"
            android:textAllCaps="false"
            android:textSize="10sp"
            android:textColor="#000"
            android:backgroundTint="#00c853" />
    </LinearLayout>

    <!-- Search match info -->
    <TextView
        android:id="@+id/searchInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#ff8c00"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:visibility="gone"
        android:paddingBottom="4dp" />

    <!-- Terminal log area -->
    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_log_area"
        android:padding="8dp"
        android:fadeScrollbars="false"
        android:scrollbarThumbVertical="@android:color/darker_gray">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#00e676"
            android:fontFamily="monospace"
            android:padding="4dp"
            android:lineSpacingMultiplier="1.3"
            android:textIsSelectable="true" />
    </ScrollView>

    <!-- Hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Long-press to select text  ·  Search to filter by keyword"
        android:textColor="#1e3848"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingTop="5dp" />

</LinearLayout>
